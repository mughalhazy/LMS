{
  "event_name": "course_enrolled",
  "topic": "lms.course.enrolled.v1",
  "producer_service": "course-service",
  "schema_version": 1,
  "purpose": "Published when a learner is enrolled in a course so progress tracking, notifications, and compliance workflows can initialize enrollment-dependent processes.",
  "payload": {
    "tenant_id": "string",
    "course_id": "string",
    "enrollment_id": "string",
    "learner_id": "string",
    "enrolled_by": "string",
    "enrollment_source": "self|manager|admin|integration",
    "due_at": "date-time|null",
    "status": "active",
    "enrolled_at": "date-time"
  },
  "consumers": [
    "progress-tracking-service",
    "notification-service",
    "assessment-service",
    "analytics-reporting-service",
    "compliance-reporting-service",
    "audit-compliance-service"
  ]
}
