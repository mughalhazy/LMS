{
  "events": [
    {
      "event_name": "course.lifecycle.created.v1",
      "topic": "course.lifecycle",
      "description": "Emitted when a course aggregate is created in draft state.",
      "required_payload": ["status"]
    },
    {
      "event_name": "course.lifecycle.updated.v1",
      "topic": "course.lifecycle",
      "description": "Emitted when course metadata changes.",
      "required_payload": ["updated_fields"]
    },
    {
      "event_name": "course.lifecycle.published.v1",
      "topic": "course.lifecycle",
      "description": "Emitted when publish status changes.",
      "required_payload": ["publish_status"]
    },
    {
      "event_name": "course.lifecycle.archived.v1",
      "topic": "course.lifecycle",
      "description": "Emitted when a course is archived.",
      "required_payload": ["status"]
    },
    {
      "event_name": "course.linkage.program.updated.v1",
      "topic": "course.linkage",
      "description": "Emitted when program links are replaced for a course.",
      "required_payload": ["program_links"]
    },
    {
      "event_name": "course.linkage.session.updated.v1",
      "topic": "course.linkage",
      "description": "Emitted when session links are replaced for a course.",
      "required_payload": ["session_links"]
    }
  ]
}
