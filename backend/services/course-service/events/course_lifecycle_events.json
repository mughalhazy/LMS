{
  "events": [
    {
      "event_type": "course.lifecycle.created.v1",
      "topic": "course.lifecycle",
      "description": "Emitted when a course aggregate is created in draft state.",
      "required_payload": [
        "tenant_id",
        "correlation_id",
        "status"
      ]
    },
    {
      "event_type": "course.lifecycle.updated.v1",
      "topic": "course.lifecycle",
      "description": "Emitted when course metadata changes.",
      "required_payload": [
        "tenant_id",
        "correlation_id",
        "updated_fields"
      ]
    },
    {
      "event_type": "course.lifecycle.published.v1",
      "topic": "course.lifecycle",
      "description": "Emitted when publish status changes.",
      "required_payload": [
        "tenant_id",
        "correlation_id",
        "publish_status"
      ]
    },
    {
      "event_type": "course.lifecycle.archived.v1",
      "topic": "course.lifecycle",
      "description": "Emitted when a course is archived.",
      "required_payload": [
        "tenant_id",
        "correlation_id",
        "status"
      ]
    },
    {
      "event_type": "course.linkage.program.updated.v1",
      "topic": "course.linkage",
      "description": "Emitted when program links are replaced for a course.",
      "required_payload": [
        "tenant_id",
        "correlation_id",
        "program_links"
      ]
    },
    {
      "event_type": "course.linkage.session.updated.v1",
      "topic": "course.linkage",
      "description": "Emitted when session links are replaced for a course.",
      "required_payload": [
        "tenant_id",
        "correlation_id",
        "session_links"
      ]
    }
  ]
}
