      "lesson_id",
      "tenant_id",
      "correlation_id",
      "delivery_state",
      "version"
    ],
    "properties": {
      "lesson_id": {
        "type": "string"
      },
      "tenant_id": {
        "type": "string"
      },
      "correlation_id": {
        "type": "string"
      },
      "delivery_state": {
        "type": "object",
        "additionalProperties": true
      },
      "version": {
        "type": "integer",
        "minimum": 1
      }
    }
  }
}
