{
  "event_name": "lesson_archived",
  "event_version": "v1",
  "topic": "lms.lesson.archived.v1",
  "producer_service": "lesson-service",
  "description": "Published when a lesson is archived and no longer mutable.",
  "payload_schema": {
    "type": "object",
    "required": ["lesson_id", "tenant_id", "course_id", "status", "archived_at"],
    "properties": {
      "lesson_id": {"type": "string"},
      "tenant_id": {"type": "string"},
      "course_id": {"type": "string"},
      "status": {"const": "archived"},
      "archived_at": {"type": "string", "format": "date-time"}
    }
  }
}
