FROM python:3.11-slim

ARG SERVICE_PATH
ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1

WORKDIR /app

COPY ${SERVICE_PATH}/requirements.txt /tmp/requirements.txt
RUN pip install --no-cache-dir -r /tmp/requirements.txt

COPY ${SERVICE_PATH}/ /app/
COPY infrastructure/deployment/scripts/start-service.sh /usr/local/bin/start-service.sh
RUN chmod +x /usr/local/bin/start-service.sh

EXPOSE 8000
ENTRYPOINT ["/usr/local/bin/start-service.sh"]
