LMS_ENV=deployment
LOG_LEVEL=info
DATABASE_URL=postgresql://lms:lms@postgres:5432/lms
REDIS_URL=redis://redis:6379/0
EVENT_BUS_URL=amqp://guest:guest@rabbitmq:5672/
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317

# Load-test hardening defaults
API_GATEWAY_WORKERS=8
API_GATEWAY_MAX_CONNECTIONS=20000
UPSTREAM_POOL_MAX_CONNECTIONS=2000
UPSTREAM_POOL_MAX_IDLE=300
UPSTREAM_POOL_IDLE_TIMEOUT_SECONDS=90
DB_POOL_MIN_SIZE=20
DB_POOL_MAX_SIZE=120
DB_POOL_MAX_OVERFLOW=40
REDIS_CACHE_MAX_CONNECTIONS=500
EVENT_INGESTION_BATCH_SIZE=500
EVENT_INGESTION_WORKERS=12
ANALYTICS_CONSUMER_CONCURRENCY=16
CACHE_DEFAULT_TTL_SECONDS=30
