{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "lms/topic-definition.schema.json",
  "title": "LMS Event Topic Definition",
  "type": "object",
  "required": ["event_type", "topic", "producer_service", "consumer_services", "contract_file", "schema_ref"],
  "properties": {
    "event_type": { "type": "string", "minLength": 1 },
    "topic": { "type": "string", "pattern": "^lms\\.[a-z0-9_]+(?:\\.[a-z0-9_]+)+\\.v[0-9]+$" },
    "producer_service": { "type": "string", "pattern": "^[a-z0-9-]+-service$" },
    "consumer_services": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "pattern": "^[a-z0-9-]+-service$" }
    },
    "contract_file": { "type": "string", "minLength": 1 },
    "schema_ref": { "type": "string", "minLength": 1 }
  },
  "additionalProperties": false
}
