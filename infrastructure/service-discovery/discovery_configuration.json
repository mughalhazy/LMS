{
  "service_registry": {
    "provider": "consul",
    "address_env": "SERVICE_REGISTRY_ADDRESS",
    "datacenter_env": "SERVICE_REGISTRY_DATACENTER"
  },
  "lookup": {
    "scheme": "discovery://",
    "resolver": "service-registry",
    "cache_ttl": "30s",
    "retry_policy": {
      "max_attempts": 3,
      "backoff": "250ms"
    }
  },
  "services": {
    "ai-tutor-service": {
      "service_name": "ai-tutor-service",
      "service_id": "ai-tutor-service-${HOSTNAME}",
      "registration": {
        "enabled": true,
        "registry": "consul",
        "address_env": "SERVICE_HOST",
        "port_env": "SERVICE_PORT",
        "tags": [
          "lms",
          "microservice",
          "ai-tutor-service"
        ]
      },
      "health_check": {
        "http_path": "/health",
        "interval": "10s",
        "timeout": "2s",
        "deregister_after": "60s"
      },
      "runtime": "python",
      "startup": {
        "register_on_startup": true,
        "deregister_on_shutdown": true
      }
    },
